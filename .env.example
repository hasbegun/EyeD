# EyeD Mode Configuration
# Copy this file to .env and set EYED_MODE to dev or test.
# If .env is absent, all services default to prod (safe-by-default).
#
# Usage:
#   cp .env.example .env
#   echo "EYED_MODE=dev" > .env

# Operational mode: dev | test | prod
# Absent or prod  → FHE always ON, allow_plaintext=false, log_level=warn
# dev             → FHE toggleable, allow_plaintext=true,  log_level=debug
# test            → FHE toggleable, allow_plaintext=true,  log_level=info
EYED_MODE=dev

# --- Optional overrides (take precedence over mode defaults) ---

# Override log level independently of mode (debug | info | warn | error)
# EYED_LOG_LEVEL=debug

# Override FHE enabled flag independently of mode (true | false)
# EYED_FHE_ENABLED=true

# Override plaintext fallback independently of mode (true | false)
# WARNING: setting this to true in prod weakens security guarantees.
# EYED_ALLOW_PLAINTEXT=false
